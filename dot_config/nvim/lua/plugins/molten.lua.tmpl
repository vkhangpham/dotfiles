{{- $moltenPython := or (get . "molten_python_host") (joinPath .chezmoi.homeDir ".venvs/nvim/bin/python") -}}
return {
  {
    "benlubas/molten-nvim",
    version = "*",
    -- Register remote plugin once after install/update
    build = ":UpdateRemotePlugins",

    -- Minimal, safe defaults
    init = function()
      -- Use the Python that has pynvim + jupyter_client + ipykernel + nbformat installed
      -- CHANGE THIS PATH to your venv
      vim.g.python3_host_prog = "{{ $moltenPython }}"

      -- Keep images off unless you’ve set up image.nvim/wezterm/kitty
      vim.g.molten_image_provider = "none"
      vim.g.molten_auto_open_output = false
      vim.g.molten_virt_text_output = true
      vim.g.molten_virt_text_max_lines = 15
      vim.g.molten_wrap_output = true
      vim.g.molten_output_win_border = "rounded"
      vim.g.molten_output_win_hide_on_leave = true
      vim.g.molten_tick_rate = 200
    end,

    config = function()
      local map = function(m, lhs, rhs, desc)
        vim.keymap.set(m, lhs, rhs, { silent = true, desc = desc })
      end

      -- Kernel + eval basics (usable in .py buffers)
      map("n", "<localleader>mi", function()
        vim.cmd.MoltenInit()
      end, "Molten: init kernel")

      map("n", "<localleader>e", function()
        vim.cmd.MoltenEvaluateOperator()
      end, "Molten: eval {motion}")

      map("n", "<localleader>rl", function()
        vim.cmd.MoltenEvaluateLine()
      end, "Molten: eval line")

      -- FIXED: preserve visual range and reselect
      map("v", "<localleader>r", ":<C-u>MoltenEvaluateVisual<CR>gv", "Molten: eval visual")

      map("n", "<localleader>rr", function()
        vim.cmd.MoltenReevaluateCell()
      end, "Molten: re-eval cell")

      map("n", "<localleader>rd", function()
        vim.cmd.MoltenDelete()
      end, "Molten: delete cell")

      map("n", "<localleader>os", function()
        vim.cmd([[noautocmd MoltenEnterOutput]])
      end, "Molten: enter output")

      map("n", "<localleader>oh", function()
        vim.cmd.MoltenHideOutput()
      end, "Molten: hide output")

      map("n", "<localleader>rk", function()
        vim.cmd.MoltenInterrupt()
      end, "Molten: interrupt kernel")
    end,
  },
}
